{
  "appId": "uz.avtojon.app",
  "appName": "Avtojon",
  "webDir": "dist",
  "server": {
    "url": "https://avtojon.uz",
    "cleartext": true
  },
  "plugins": {
    "Geolocation": {
      "permissions": ["location", "coarseLocation"]
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "DARK",
      "backgroundColor": "#7c3aed"
    }
  },
  "android": {
    "allowMixedContent": true
  }
}