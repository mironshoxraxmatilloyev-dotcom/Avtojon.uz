# Server
NODE_ENV=development
PORT=3000

# MongoDB
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/avtojon?retryWrites=true&w=majority

# JWT
# Kuchli va uzun secret key ishlatish tavsiya etiladi
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-jwt-secret
JWT_EXPIRES_IN=7d

# Redis (ixtiyoriy - yo'q bo'lsa in-memory ishlatiladi)
# Redis ishlatish uchun REDIS_ENABLED=true qiling
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS
# Vergul bilan ajratilgan URL lar
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
