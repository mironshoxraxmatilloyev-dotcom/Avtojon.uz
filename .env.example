# ============================================
# AVTOJON PRODUCTION ENVIRONMENT
# Bu faylni apps/api/.env ga ko'chiring va to'ldiring
# ============================================

# Server
NODE_ENV=production
PORT=3000

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/avtojon

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Redis (ixtiyoriy - rate limiting uchun)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=https://avtojon.uz,https://www.avtojon.uz

# Frontend (build paytida ishlatiladi)
VITE_API_URL=/api

# ============================================
# TO'LOV TIZIMLARI
# ============================================

# -------- PAYME --------
# Payme merchant kabinetidan oling: https://merchant.paycom.uz
# 1. Merchant ID - "Sozlamalar" bo'limida
# 2. Secret Key - "Kalitlar" bo'limida yarating
# 3. Callback URL ni "Endpoint URL" ga qo'shing: https://avtojon.uz/api/payments/payme

PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_secret_key

# -------- CLICK --------
# Click merchant kabinetidan oling: https://merchant.click.uz
# 1. Merchant ID - asosiy sahifada
# 2. Service ID - "Xizmatlar" bo'limida yarating
# 3. Secret Key - xizmat sozlamalarida
# 4. Callback URL larni sozlang:
#    - Prepare URL: https://avtojon.uz/api/payments/click/prepare
#    - Complete URL: https://avtojon.uz/api/payments/click/complete

CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret_key

# -------- URL LAR --------
FRONTEND_URL=https://avtojon.uz
API_URL=https://avtojon.uz

# ============================================
# OPENAI (Ovozli kiritish uchun)
# ============================================
OPENAI_API_KEY=your_openai_api_key
