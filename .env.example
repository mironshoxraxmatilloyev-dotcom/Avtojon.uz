# ============================================
# AVTOJON PRODUCTION ENVIRONMENT
# Bu faylni apps/api/.env ga ko'chiring va to'ldiring
# ============================================

# Server
NODE_ENV=production
PORT=3000

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/avtojon

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Redis (ixtiyoriy - rate limiting uchun)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=https://avtojon.uz,https://www.avtojon.uz

# Frontend (build paytida ishlatiladi)
VITE_API_URL=/api
